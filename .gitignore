# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
.installed.cfg
*.egg
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Virtual environments (any local recipe — dev, portable, release)
.venv/
.venv-portable/
.venv-release/
.env/
env/
venv/

# Embedded Python sidecar (bootstrapped by scripts/bootstrap_embedded_python.ps1)
runtime/python/

# PyInstaller build artifacts (regeneratable from source)
build/
dist/

# Model weights — too large for git; users supply their own
models/*.gguf
models/*.onnx
models/*.safetensors
models/*.bin
# Keep the directory itself trackable
!models/.gitkeep

# Vendored accelerator binaries (large, harvested per-host)
vendor/accelerators/bin/
vendor/lemonade/bin/

# Per-user state and runtime artifacts
*.log
*.log.*
*.pid
*.broken
*.partial
*_MEI*/
RELEASE-MANIFEST.txt

# OS / IDE
.DS_Store
Thumbs.db
desktop.ini
.idea/
.vscode/
*.swp
*~

# Lock files generated at build time
requirements-lock.txt

# Generated by scripts/build_windows.ps1 — bakes BUILD_VARIANT + BUILD_TIMESTAMP
# into the package right before PyInstaller runs. Never check in (would pin
# every dev's local clone to the variant the last build target used).
src/omega_studio/_build_info.py

# Local wheel cache for variant builds. The Vulkan / DML / CUDA wheels can be
# multi-tens-of-MB and aren't worth bloating git history. Each release
# attaches the relevant wheels as GitHub release assets; the build script
# picks them up locally if `vendor/wheels/<variant>/*.whl` is populated.
vendor/wheels/
